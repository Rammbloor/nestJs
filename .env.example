NODE_ENV=dev
SERVER_PORT=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=home_work

SWAGGER_LOGIN=admin
SWAGGER_PASSWORD=admin
SWAGGER_PATH=/docs
SCALAR_PATH=/docs/scalar

THROTTLER_TTL=1
THROTTLER_LIMIT=10
AUTH_REGISTER_THROTTLE_TTL=60
AUTH_REGISTER_THROTTLE_LIMIT=3
AUTH_LOGIN_THROTTLE_TTL=60
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_REFRESH_THROTTLE_TTL=60
AUTH_REFRESH_THROTTLE_LIMIT=20

CORS_ORIGINS=http://localhost:3000

JWT_ACCESS_TTL=2h
JWT_ACCESS_SECRET_KEY=change-me-access-secret
JWT_REFRESH_TTL=7d
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret

AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SAME_SITE=lax
